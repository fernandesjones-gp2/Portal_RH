# ============================================================
# Portal RH — Template de variáveis de ambiente
# Copie para .env e preencha com os valores reais.
#   cp .env.example .env
#
# Arquitetura NOVA (pós-migração): Postgres próprio + Auth.js (Google).
# Estas variáveis são server-only — NÃO use prefixo NEXT_PUBLIC_
# (segredos com NEXT_PUBLIC_ são embutidos no bundle do cliente no build).
# ============================================================

# ---- Banco de dados (Postgres próprio no EasyPanel) ----
DATABASE_URL=postgres://USUARIO:SENHA@HOST:PORTA/BANCO

# ---- Auth.js (NextAuth v5) ----
# Gere o secret com: openssl rand -base64 32
AUTH_SECRET=gere-um-secret-aqui
# URL pública da aplicação (sem barra no final)
#   Local:    http://localhost:3000
#   Produção: https://gp2-rh-app.rockhub.co
AUTH_URL=http://localhost:3000

# ---- Google OAuth (criar em https://console.cloud.google.com/apis/credentials) ----
# Authorized redirect URI no Google:
#   https://gp2-rh-app.rockhub.co/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google   (para dev local)
AUTH_GOOGLE_ID=seu-google-client-id
AUTH_GOOGLE_SECRET=seu-google-client-secret
