# ============================================================
# Portal RH — Template de variáveis de ambiente
# Copie para .env e preencha com os valores reais.
#   cp .env.example .env
#
# ATENCAO: variáveis NEXT_PUBLIC_* são embutidas no bundle do
# cliente DURANTE O BUILD (next build), não em runtime. No deploy
# via Docker/EasyPanel elas precisam estar disponíveis no momento
# do build (como build args), senão o app usa os placeholders.
# ============================================================

# URL do projeto Supabase (ex.: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave pública (anon) do Supabase — pode ir para o client
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Porta do servidor (opcional — default 3000)
# PORT=3000
